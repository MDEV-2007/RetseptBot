# Copy to .env and fill in your values:  cp .env.example .env

# ── Django core ───────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False

# Comma-separated, no spaces
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,<SERVER-IP>

# Comma-separated origins for CSRF (include https:// in production)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Set True only after HTTPS is confirmed working
SECURE_SSL_REDIRECT=False

# ── SQLite path (Docker volume mount point) ───────────────────────────────────
DB_PATH=/app/db.sqlite3

# ── Telegram bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIjKlMnOpQrStUvWxYz
TELEGRAM_BOT_USERNAME=YourBotUsername

# ── Public app URL (used in share links & bot messages) ───────────────────────
# No trailing slash
DJANGO_APP_URL=https://yourdomain.com
